<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Majestic Main Mountain Peak in background -->
    <path
        android:pathData="M24,78 L54,30 L84,78 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="24"
                android:startY="30"
                android:endX="84"
                android:endY="78"
                android:type="linear">
                <item android:offset="0" android:color="#FFFFFF" />
                <item android:offset="1" android:color="#CBD5E1" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Alpenglow sunrise cap -->
    <path
        android:pathData="M54,30 L45,44 L50,42 L54,48 L58,42 L63,44 Z"
        android:fillColor="#FF6D80" />
    <!-- Secondary rocky base peak overlay -->
    <path
        android:pathData="M44,78 L65,46 L82,78 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="46"
                android:endX="82"
                android:endY="78"
                android:type="linear">
                <item android:offset="0" android:color="#94A3B8" />
                <item android:offset="1" android:color="#1E293B" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Radiant Alpine Sun rising between ridges -->
    <path
        android:pathData="M70,36 A 6 6 0 1 1 70,35.99 A 6 6 0 0 1 70,36 Z"
        android:fillColor="#FFFFB03A" />
</vector>
